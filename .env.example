# --- CONFIGURAÇÕES DO SERVIDOR ---
PORT=3000
NODE_ENV=development

# --- ASAAS (PAGAMENTOS SaaS) ---
# Gere em: Painel Asaas -> Configurações -> Integrações
ASAAS_API_KEY=sua_chave_aqui
ASAAS_WEBHOOK_SECRET=token_escolhido_para_o_webhook

# --- GROQ (IA DO BOT) ---
# Gere em: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_groq_aqui

# --- WHATSAPP ---
# Nome do dispositivo no WhatsApp
WHATSAPP_DEVICE_NAME=CarFlow_SaaS
